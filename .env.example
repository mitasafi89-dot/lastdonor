# =============================================================================
# LastDonor - Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local
#
# Required vars are marked [REQUIRED], optional ones [OPTIONAL].
# =============================================================================

# ── Database (PostgreSQL) ────────────────────────────────────────────────────
# [REQUIRED] PostgreSQL connection string (Supabase, Neon, or local)
DATABASE_URL=postgresql://user:password@localhost:5432/lastdonor

# ── Auth (NextAuth v5) ───────────────────────────────────────────────────────
# [REQUIRED] Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
# [REQUIRED] App base URL (http://localhost:3000 for local dev)
NEXTAUTH_URL=http://localhost:3000

# [OPTIONAL] Google OAuth (for social login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Stripe (Payments) ───────────────────────────────────────────────────────
# [REQUIRED] Stripe secret key (sk_test_...)
STRIPE_SECRET_KEY=
# [REQUIRED] Publishable key - exposed to browser (pk_test_...)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# [REQUIRED] Webhook signing secret (whsec_...)
STRIPE_WEBHOOK_SECRET=
# [OPTIONAL] Connect webhook secret - for Stripe Connect payouts
STRIPE_CONNECT_WEBHOOK_SECRET=

# ── Supabase (File Storage) ─────────────────────────────────────────────────
# [REQUIRED] Supabase project URL
SUPABASE_URL=
# [REQUIRED] Supabase service role key (NOT the anon key)
SUPABASE_SERVICE_ROLE_KEY=

# ── Email (Resend) ──────────────────────────────────────────────────────────
# [REQUIRED] Resend API key for transactional emails
RESEND_API_KEY=
# [OPTIONAL] Secret for newsletter unsubscribe link signing
NEWSLETTER_UNSUBSCRIBE_SECRET=

# ── Sentry (Error Tracking) ─────────────────────────────────────────────────
# [OPTIONAL] Sentry DSN - server-side
SENTRY_DSN=
# [OPTIONAL] Sentry DSN - client-side (browser)
NEXT_PUBLIC_SENTRY_DSN=
# [OPTIONAL] Sentry org/project for source maps upload
SENTRY_ORG=
SENTRY_PROJECT=

# ── AI / OpenRouter ─────────────────────────────────────────────────────────
# [OPTIONAL] OpenRouter API key for blog generation
OPENROUTER_API_KEY=
# [OPTIONAL] Fallback key if primary runs out of credits
OPENROUTER_API_KEY_FALLBACK=

# ── Kling AI (Image Generation) ─────────────────────────────────────────────
# [OPTIONAL] Kling AI credentials for blog hero images
KLING_ACCESS_KEY=
KLING_SECRET_KEY=
KLING_API_URL=
KLING_MODEL=

# ── Identity Verification (Veriff) ──────────────────────────────────────────
# [OPTIONAL] Veriff credentials for campaign creator verification
VERIFF_API_KEY=
VERIFF_SHARED_SECRET=
VERIFF_BASE_URL=https://stationapi.veriff.com
VERIFF_CALLBACK_BASE=

# ── News API ─────────────────────────────────────────────────────────────────
# [OPTIONAL] GNews API key for news-to-blog pipeline
GNEWS_API_KEY=

# ── Blog Pipeline ───────────────────────────────────────────────────────────
# [OPTIONAL] Toggle automated blog generation
BLOG_PIPELINE_ENABLED=false
BLOG_MAX_POSTS_PER_DAY=3
BLOG_AUTO_PUBLISH=false
BLOG_MIN_PRIORITY_SCORE=50

# ── Cron / Security ─────────────────────────────────────────────────────────
# [REQUIRED] Secret to authenticate cron job requests
CRON_SECRET=
# [REQUIRED] 32-byte hex key for encrypting settings. Generate with: openssl rand -hex 32
SETTINGS_ENCRYPTION_KEY=

# ── App URLs ─────────────────────────────────────────────────────────────────
# [OPTIONAL] Public app URL (used in emails, OG images, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000
